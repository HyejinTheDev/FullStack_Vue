@inherits LayoutComponentBase

<div class="app-layout">
    @if (_isLoggedIn)
    {
        <nav class="navbar">
            <div class="navbar-inner container">
                <div class="navbar-brand">
                    <div class="logo-icon">💳</div>
                    <div class="brand-text">
                        <span class="brand-name">PaymentService</span>
                        <span class="brand-tag">Nhóm 9</span>
                    </div>
                </div>

                <div class="navbar-links">
                    <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">📄 Hóa đơn</NavLink>
                    @if (_userRole == "Admin")
                    {
                        <NavLink href="/users" class="nav-link">👥 Users</NavLink>
                        <NavLink href="/reports" class="nav-link">📊 Báo cáo</NavLink>
                    }
                </div>

                <div class="navbar-user">
                    <div class="user-info">
                        <span class="user-name">@_userName</span>
                        <span class="user-role badge @(_userRole == "Admin" ? "badge-paid" : "badge-pending")">@_userRole</span>
                    </div>
                    <button class="btn btn-ghost btn-sm" @onclick="Logout">Đăng xuất</button>
                </div>
            </div>
        </nav>
    }

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private bool _isLoggedIn;
    private string _userName = "";
    private string _userRole = "";

    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private AuthStateService AuthState { get; set; } = default!;

    protected override void OnInitialized()
    {
        AuthState.OnChange += UpdateState;
        UpdateState();
    }

    private void UpdateState()
    {
        _isLoggedIn = AuthState.IsLoggedIn;
        _userName = AuthState.UserName;
        _userRole = AuthState.UserRole;
        InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        AuthState.Logout();
        Nav.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        AuthState.OnChange -= UpdateState;
    }
}
